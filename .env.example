# Variables d'environnement attendues par le serveur Hordes Revival.
# Copier en `.env` pour le dev local (ce fichier est git-ignored).
# En production (Render / Railway), elles sont configurées via le dashboard.

# Secret JWT — DOIT faire au moins 32 caractères en prod. En dev, n'importe quelle
# chaîne longue convient. NE JAMAIS commiter le secret réel.
JWT_SECRET=dev-secret-please-change-me-at-least-32-chars

# Port et hôte d'écoute Fastify.
PORT=3000
HOST=127.0.0.1

# `production` active les cookies Secure (HTTPS uniquement). Laisser vide ou
# `development` en local.
NODE_ENV=development

# URL Postgres. Si vide, le backend MemoryStore est utilisé (volatile, OK pour
# `npm run start` en local mais pas pour la prod).
# Format : postgres://user:password@host:port/dbname
# DATABASE_URL=postgres://hordes:hordes@127.0.0.1:5432/hordes

# Durée d'une journée de jeu en millisecondes. 24h par défaut.
# DAY_DURATION_MS=86400000
