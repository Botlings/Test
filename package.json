{
  "name": "hordes-revival",
  "version": "0.1.0",
  "description": "Hordes Revival — browser game multijoueur de survie face aux hordes de zombies",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').cpSync('src/persistence/sql','dist/src/persistence/sql',{recursive:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx src/index.ts",
    "start": "tsx src/server/main.ts",
    "start:prod": "node dist/src/server/main.js"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/websocket": "^11.2.0",
    "@types/ws": "^8.18.1",
    "fastify": "^5.8.5",
    "hash-wasm": "^4.12.0",
    "pg": "^8.21.0",
    "ws": "^8.21.0"
  }
}
